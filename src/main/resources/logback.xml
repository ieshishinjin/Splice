<?xml version="1.0" encoding="UTF-8"?>
<configuration debug="false" scan="false">

    <!-- Console appender -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%highlight(%level) %msg%n</pattern>
        </encoder>
        <filter class="ch.qos.logback.classic.filter.ThresholdFilter">
            <level>INFO</level>
        </filter>
    </appender>

    <!-- File appender for detailed logs -->
    <appender name="FILE" class="ch.qos.logback.core.FileAppender">
        <file>${user.home}/.splice/logs/splice.log</file>
        <append>true</append>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <root level="DEBUG">
        <appender-ref ref="FILE" />
    </root>

    <!-- Default: INFO to console -->
    <logger name="io.github.ieshishinjin.splice" level="INFO">
        <appender-ref ref="CONSOLE" />
    </logger>

    <!-- Suppress verbose internal libraries -->
    <logger name="ch.qos.logback" level="WARN" />
    <logger name="org.apache" level="WARN" />
    <logger name="org.objectweb" level="WARN" />
    <logger name="org.slf4j" level="WARN" />
</configuration>
