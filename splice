#!/usr/bin/env bash
set -e

# Splice 启动脚本 — 在项目根目录直接执行
# Usage: ./splice [options]
#   ./splice -I                          # 交互模式
#   ./splice -s 1.20.1 -t 1.21 -l forge -i ./MyMod

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
JAR="$SCRIPT_DIR/build/libs/Splice-1.0.0-all.jar"

if [ ! -f "$JAR" ]; then
    echo "→ 构建 Splice..."
    cd "$SCRIPT_DIR"
    ./gradlew :shadowJar -q
fi

exec java -jar "$JAR" "$@"
